# Project Deliverable 1: Data Collection, Cleaning, and Exploration

# Import Libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Enable plots
%matplotlib inline

# Load Dataset
data = pd.read_csv("superstore.csv")

# Display first rows
print("First 5 Rows:")
print(data.head())

# Dataset Info
print("\nDataset Shape:", data.shape)
print("\nDataset Info:")
print(data.info())

# Statistical Summary
print("\nStatistical Summary:")
print(data.describe())

# Check Missing Values
print("\nMissing Values:")
print(data.isnull().sum())

# Remove Duplicates
data = data.drop_duplicates()

# Boxplot for Outliers
plt.figure()
sns.boxplot(x=data['Sales'])
plt.title("Boxplot of Sales")
plt.show()

# Sales Distribution
plt.figure()
sns.histplot(data['Sales'], bins=10, kde=True)
plt.title("Sales Distribution")
plt.show()

# Profit by Category
plt.figure()
sns.barplot(x='Category', y='Profit', data=data)
plt.title("Profit by Category")
plt.xticks(rotation=45)
plt.show()

# Count by Category
plt.figure()
sns.countplot(x='Category', data=data)
plt.title("Count by Category")
plt.xticks(rotation=45)
plt.show()

# Correlation Heatmap
plt.figure()
sns.heatmap(data.corr(numeric_only=True), annot=True)
plt.title("Correlation Heatmap")
plt.show()

# Key Insights
print("\nKey Insights:")
print("- Technology category shows higher sales.")
print("- Profit varies across categories.")
print("- Sales and Profit are positively correlated.")
